# Base URL the frontend uses to reach the backend API.
#
# Local dev (default): leave unset — the Vite dev server proxies /api → http://localhost:8000.
# Vercel / production: set to the absolute backend URL on your VPS, e.g.
# VITE_API_URL=https://api.your-domain.com
VITE_API_URL=/api

# Only used by `aubr dev` to point the dev proxy at a non-default backend.
# VITE_API_TARGET=http://localhost:8000
